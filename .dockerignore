# ============================================================================
# .dockerignore - Fichiers à exclure du contexte Docker
# ============================================================================
# Ce fichier spécifie les fichiers et dossiers à ignorer lors de la copie
# du contexte dans l'image Docker. Cela réduit la taille de l'image et
# accélère le build en évitant de copier des fichiers inutiles.
# ============================================================================

# Archive historique (ancienne version C, anciens rapports/résultats)
archive_obsolete/

# Fichiers de build et compilation
build/
c/build/
*.o
*.bin
*.a
*.so

# Modèles sauvegardés (générés lors de l'exécution)
models/*.bin
models/*.txt
results/models/*.bin

# Résultats générés (métriques, graphiques, logs)
results/
*.log

# Datasets prétraités (générés lors de l'exécution)
data/processed/

# Environnements virtuels Python (non nécessaires dans Docker)
venv/
env/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Fichiers de configuration IDE (non nécessaires dans Docker)
.vscode/
.idea/
*.swp
*.swo
*~

# Fichiers Git (non nécessaires dans l'image)
.git/
.gitignore
.gitattributes

# Documentation de développement (optionnel, peut être inclus si nécessaire)
# docs/presentation/
# docs/rapport/

# Fichiers temporaires et cache
*.tmp
*.temp
.cache/
.pytest_cache/
.coverage
htmlcov/

# Fichiers système
.DS_Store
Thumbs.db

